# 1. Gmail SMTP Sender Account Credentials
# The Gmail address that will authenticate and send the emails
GMAIL_USER=client@gmail.com

# The 16-character App Password generated from your Google Account
# Guide: https://support.google.com/accounts/answer/185833
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# 2. Recipient Email Address
# The email address where notifications and booking requests will be delivered
CONTACT_EMAIL=client@gmail.com
