# ==============================================================================
# ENVIRONMENT VARIABLES CONFIGURATION - SHABBIR CONSULTANT PORTFOLIO
# ==============================================================================

# 1. Resend API Key from your Resend Dashboard (https://resend.com/dashboard)
# Local Testing Key (starts with re_...)
RESEND_API_KEY=re_your_api_key_here

# 2. Recipient Email Address where notifications should be sent
# For testing: Change this to your Resend registered owner email (e.g., siddiqpathan601@gmail.com)
# For production: Set this to Shabbir's actual recipient address
CONTACT_EMAIL=shabbirmsb@gmail.com

# 3. Sender Email Address ("From" field)
# For testing: Must use "onboarding@resend.dev"
# For production: Set to your verified custom domain address (e.g., "Consultation <contact@yourdomain.com>")
RESEND_FROM_EMAIL=onboarding@resend.dev
